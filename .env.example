# Site Configuration
NEXT_PUBLIC_SITE_URL=https://hooshyar.sepehr.homes

# Authentication
# NEXTAUTH_URL must be set to your production URL (no trailing slash)
NEXTAUTH_URL=https://hooshyar.sepehr.homes
NEXTAUTH_SECRET=your-nextauth-secret-here
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH_BASE64=your-bcrypt-hash-base64-encoded-here

# Upstash Redis (via Vercel KV / Redis integration) — store leads, chat sessions, dashboard stats, dynamic content
# Create a KV database in the Vercel dashboard (Storage → KV) and copy the credentials,
# or add an Upstash Redis integration from the Vercel Marketplace.
# The env var names KV_REST_API_URL and KV_REST_API_TOKEN are the same either way.
KV_REST_API_URL=https://your-region-key.upstash.io
KV_REST_API_TOKEN=your-kv-rest-api-token-here
# Optional read-only token (if you need a separate read-only connection)
KV_REST_API_READ_ONLY_TOKEN=

# Groq API (Chatbot)
GROQ_API_KEY=your-groq-api-key-here

# Email (Contact Form via Resend)
RESEND_API_KEY=your-resend-api-key-here
CONTACT_TO_EMAIL=your-email@example.com
CONTACT_FROM_EMAIL=your-website@example.com
